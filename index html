body {
  font-family: Arial;
  background: #0f172a;
  color: white;
  text-align: center;
}

.container {
  margin-top: 50px;
}

.page {
  display: block;
}

.hidden {
  display: none;
}

input, select {
  padding: 10px;
  margin: 10px;
}

button {
  padding: 10px 20px;
  background: #22c55e;
  border: none;
  color: white;
  cursor: pointer;
}

button:hover {
  background: #16a34a;
}
